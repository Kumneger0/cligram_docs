---
import Analytics from "@vercel/analytics/astro";
import "../global.css";

const title = "Cligram – Terminal Telegram Client";
const description =
  "A CLI Telegram client with Ghost Mode. Read messages and view stories anonymously.";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <Analytics />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>

  <body class="bg-neutral-950 text-neutral-100 antialiased">
    <nav class="border-b border-neutral-800/50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2.5 text-lg font-semibold">
           
            <span>cligram</span>
          </a>
          
          <div class="flex items-center gap-6">
            <a href="/docs" class="text-sm text-neutral-400 hover:text-neutral-100 transition-colors">
              Docs
            </a>
            <a 
              href="https://github.com/Kumneger0/cligram" 
              class="text-sm text-neutral-400 hover:text-neutral-100 transition-colors"
            >
              GitHub
            </a>
          </div>
        </div>
      </div>
    </nav>

    <section class="px-6 lg:px-8 py-20">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
            Telegram client for your terminal
          </h1>
          
          <p class="text-lg text-neutral-400 mb-8 leading-relaxed">
            Browse Telegram with Ghost Mode. Read messages, view stories, and check status—all without 
            read receipts, online indicators, or typing notifications. Stay completely invisible.
          </p>
          
          <div class="flex items-center gap-3">
            <a 
              href="/docs" 
              class="px-5 py-2.5 bg-neutral-100 text-neutral-950 font-medium rounded-md hover:bg-neutral-200 transition-colors"
            >
              Get Started
            </a>
            <a 
              href="https://github.com/Kumneger0/cligram" 
              class="px-5 py-2.5 text-neutral-300 font-medium hover:text-neutral-100 transition-colors"
            >
              View on GitHub →
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="bg-neutral-900 rounded-lg border border-neutral-800 overflow-hidden shadow-2xl">
          <div class="flex items-center gap-2 px-4 py-3 bg-neutral-900/50 border-b border-neutral-800">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-neutral-700"></div>
              <div class="w-3 h-3 rounded-full bg-neutral-700"></div>
              <div class="w-3 h-3 rounded-full bg-neutral-700"></div>
            </div>
            <span class="text-xs text-neutral-500 ml-2 font-mono">cligram</span>
          </div>
          <div class="p-1">
            <img src="/demo.gif" alt="Cligram terminal demo" class="w-full rounded-b" />
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold mb-3">
            Built for the terminal
          </h2>
          <p class="text-neutral-400">
            Fast, private, and keyboard-driven
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="p-6 rounded-lg bg-neutral-900/50 border border-neutral-800/50">
            <div class="text-3xl mb-4">👻</div>
            <h3 class="text-lg font-semibold mb-2">Ghost Mode</h3>
            <p class="text-sm text-neutral-400 leading-relaxed">
              Read messages and view stories without sending read receipts or notifications.
            </p>
          </div>

          <div class="p-6 rounded-lg bg-neutral-900/50 border border-neutral-800/50">
            <div class="text-3xl mb-4">⚡</div>
            <h3 class="text-lg font-semibold mb-2">Lightweight</h3>
            <p class="text-sm text-neutral-400 leading-relaxed">
              Minimal resource usage with instant response times. No bloat, just functionality.
            </p>
          </div>

          <div class="p-6 rounded-lg bg-neutral-900/50 border border-neutral-800/50">
            <div class="text-3xl mb-4">⌨️</div>
            <h3 class="text-lg font-semibold mb-2">Keyboard First</h3>
            <p class="text-sm text-neutral-400 leading-relaxed">
              Navigate everything with keyboard shortcuts. Stay in your flow without reaching for the mouse.
            </p>
          </div>
        </div>
      </div>
    </section>

    <footer class="border-t border-neutral-800/50 py-8 px-6 lg:px-8 mt-16">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-neutral-500">
          © {new Date().getFullYear()} cligram
        </p>
        
        <div class="flex items-center gap-6 text-sm text-neutral-500">
          <a href="https://github.com/Kumneger0/cligram" class="hover:text-neutral-300 transition-colors">
            GitHub
          </a>
          <a href="/docs" class="hover:text-neutral-300 transition-colors">
            Docs
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
